# NVIDIA NIM (https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embed-v1

# LaunchDarkly (server-side SDK key)
LAUNCHDARKLY_SDK_KEY=sdk-your-server-key-here

# Feature flag key in LaunchDarkly (boolean)
LD_FLAG_RAG_ENABLED=rag-enabled

# Large PDF tuning (optional — bigger batch = faster, within API limits)
CHUNK_SIZE=2000
CHUNK_OVERLAP=250
EMBED_BATCH_SIZE=48
EMBED_CONCURRENCY=4
HTTP_TIMEOUT_SECONDS=300
EMBED_MAX_RETRIES=3
